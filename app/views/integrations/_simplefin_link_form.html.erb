<% if sf_account.unlinked? %>
  <%= form_with model: sf_account, url: link_simplefin_account_path(sf_account), method: :post do |form| %>
    <%= form.label :ledger_account_id, "Account to link", class: "sr-only" %>
    <span>
      <%= form.collection_select :ledger_account_id, linkable_accounts, :id, :name, prompt: "Not linked" %>
    </span>
    <span>
      <%= form.submit "Link", "aria-label": "Link SimpleFIN account" %>
    </span>
    <span>
      <%= link_to "Import", new_account_path(simplefin_account_id: sf_account.id) %>
    </span>
  <% end %>
<% else %>
  <%= form_with model: sf_account, url: unlink_simplefin_account_path(sf_account), method: :delete, data: { turbo_confirm: "Are you sure you want to unlink this account?" } do |form| %>
    <span><%= sf_account.ledger_account.name %></span>
    <span>
      <%= form.submit "Unlink", "aria-label": "Unlink SimpleFIN account" %>
    </span>
  <% end %>
<% end %>
