<%= turbo_stream.replace dom_id(@transaction, :edit) do %>
  <%= turbo_frame_tag dom_id(@transaction, :edit), class: "edit" do %>
    <%= render partial: 'form', locals: {
      transaction: @transaction,
      accounts: @accounts,
      categories: @categories,
      account: @account
    } %>
  <% end %>
<% end %>
