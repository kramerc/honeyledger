<%= form_with(model: transaction, data: {
  controller: "transactions--form",
  action: "transactions--form#clearError",
  transactions__row_target: "form"
}, html: { autocomplete: "off" }) do |form| %>
  <div class="row" data-action="keydown.esc->transactions--row#cancelEdit">
    <div data-label="Date">
      <%= form.datetime_field :transacted_at, include_seconds: false %>
    </div>

    <div data-label="Type">
      <%= transaction_type_indicator(transaction, data: { transactions__form_target: "type" }) %>
    </div>

    <div data-label="Description">
      <%= form.text_field :description %>
    </div>

    <div data-label="From">
      <%= form.select :src_account_id,
        grouped_account_options_for_select(src_accounts, Account::SOURCEABLE, selected_key: transaction.src_account_id),
        { include_blank: "From…" },
        data: {
          action: "transactions--form#updateEnabledAccounts transactions--form#updateTypeFromSelectedAccounts",
          transactions__form_target: "srcAccount"
        } %>
    </div>

    <div data-label="To">
      <%= form.select :dest_account_id,
        grouped_account_options_for_select(dest_accounts, Account::DESTINABLE, selected_key: transaction.dest_account_id),
        { include_blank: "To…" },
        data: {
          action: "transactions--form#updateEnabledAccounts transactions--form#updateCurrency transactions--form#updateTypeFromSelectedAccounts",
          transactions__form_target: "destAccount"
        } %>
    </div>

    <div data-label="Amount" class="numeric">
      <%= form.text_field :amount, data: { transactions__form_target: "amount" } %>
    </div>

    <div data-label="Currency" data-transactions--form-target="currency">
      <%= transaction.currency&.code.presence || "—" %>
    </div>

    <div data-label="Category">
      <%= form.select :category_id, options_from_collection_for_select(categories, :id, :name), include_blank: true %>
    </div>

    <div data-label="Cleared" class="boolean">
      <%= form.check_box :cleared %>
    </div>

    <div class="actions">
      <% if transaction.new_record? %>
        <%= form.submit "Create" %>
      <% else %>
        <%= form.submit "Save" %>
        <a href="#" data-action="transactions--row#cancelEdit transactions--form#clearError">Cancel</a>
      <% end %>

      <% if transaction.errors.any? %>
        <div class="error" data-controller="error" data-transactions--form-target="error">
          <button data-action="error#close" class="close">&times;</button>
          <h4>Transaction could not be saved:</h4>
          <ul>
            <% transaction.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>
    </div>
  </div>
<% end %>
